APP_NAME=internal-docs-copilot
APP_ENV=development
APP_DEBUG=false
SQLITE_URL=sqlite+pysqlite:///./data/internal_docs_copilot.db
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./data/chroma
UPLOAD_DIR=./data/uploads
LOG_LEVEL=INFO
PDF_CHUNK_SIZE=800
PDF_CHUNK_OVERLAP=120
DEFAULT_TOP_K=5
MIN_EVIDENCE_SCORE=0.25
